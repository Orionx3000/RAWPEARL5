    "u": { "t": { "microTiming": 0.03 }, "m": { "type": "tau_synth", "model": 6, "decay": 0.3, "toneFreq": 60 }, "b": { "granularOverride": 0.2, "decayMod": 0.5 }, "desc": "Unstable Kick (Jitter)" },

