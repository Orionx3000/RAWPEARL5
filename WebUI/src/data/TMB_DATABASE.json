{
  "description": "TMB 3-Layer Domain Database: Each symbol has three domains (t/m/b). When placed on a layer, only that domain's params are used. Missing domains = {} (contributes nothing). Mid empty = silence. Hellenic chars are channel types only, excluded from grid.",
  "domains": {
    "t": "Spatial/Modulation/Routing — delay, reverb, ratchet, pan mod, probability, loop, micro timing",
    "m": "Source/Timbre — oscillator type, velocity, strike character, noise/FM flags, percussion type (required trigger)",
    "b": "Texture/Envelope — attack/decay/release mod, staccato, swell, grain density, distortion, filter sweep, LFO envelope"
  },

  "symbols": {

    " ": { "t": {}, "m": {}, "b": {}, "desc": "Empty/Silence" },

    "~": { "t": { "delaySend": 0.4 }, "m": { "oscillator": "sine", "velocity": 0.5 }, "b": {}, "desc": "Delay Send — wave shape = modulation" },
    "*": { "t": { "reverbSend": 0.4 }, "m": { "addWhiteNoise": true, "noiseLevel": 0.3, "velocity": 0.4 }, "b": {}, "desc": "Reverb Send — star burst = spatial spread" },
    "\"": { "t": { "ratchetCount": 2 }, "m": { "oscillator": "square", "velocity": 0.6 }, "b": { "staccato": true }, "desc": "Ratchet/Stutter — double marks = repeat" },
    "[": { "t": { "loopStart": true }, "m": {}, "b": {}, "desc": "Loop Start — bracket opens a region" },
    "]": { "t": { "loopEnd": true }, "m": {}, "b": {}, "desc": "Loop End — bracket closes a region" },
    "^": { "t": { "panMod": 0.3, "microTiming": -0.02 }, "m": { "oscillator": "sawtooth", "velocity": 0.5 }, "b": { "attackMod": 0.5, "filterSweep": "up" }, "desc": "LFO/Mod Up — upward arrow = rising energy" },
    "v": { "t": { "panMod": -0.3, "microTiming": 0.02 }, "m": { "oscillator": "triangle", "velocity": 0.4 }, "b": { "decayMod": 0.5, "filterSweep": "down" }, "desc": "LFO/Mod Down — downward arrow = falling energy" },
    "+": { "t": { "microTiming": 0.05, "crossFade": 0.3 }, "m": { "oscillator": "square", "velocity": 0.7, "denseStrike": true }, "b": { "crossModPop": true }, "desc": "Microtiming/Cross — plus sign = intersection" },
    "?": { "t": { "probability": 0.5 }, "m": {}, "b": {}, "desc": "Probability Gate — question = uncertainty" },

    ".": { "t": {}, "m": { "oscillator": "sine", "velocity": 0.5, "softStrike": true }, "b": { "staccato": true, "decayMod": 0.2 }, "desc": "Short Sine Pluck — dot = point, brief" },
    ",": { "t": {}, "m": { "oscillator": "sine", "velocity": 0.1, "ghostNote": true }, "b": { "staccato": true, "decayMod": 0.1 }, "desc": "Muted Ghost Note — comma = tiny, faint" },
    "-": { "t": {}, "m": { "oscillator": "sine", "velocity": 0.6, "sustain": true, "tie": true }, "b": { "attackMod": 0.3, "releaseMod": 2.0 }, "desc": "Sustain Note — dash = held line" },
    "_": { "t": {}, "m": { "oscillator": "sine", "subEmphasis": true, "subBass": true, "velocity": 0.8, "toneFreq": 60 }, "b": { "decayMod": 1.5, "attackMod": 0.3 }, "desc": "Sub Bass/Kick — underscore = deep ground" },
    "'": { "t": {}, "m": { "oscillator": "sine", "highTick": true, "velocity": 0.4, "resonance": 8 }, "b": { "staccato": true, "decayMod": 0.1 }, "desc": "High Resonance Tick — apostrophe = sharp accent" },
    "X": { "t": {}, "m": { "oscillator": "sawtooth", "denseStrike": true, "velocity": 1.0, "filterCutoff": 1.0 }, "b": { "percussive": true, "decayMod": 0.6 }, "desc": "Dense Strike (Full) — X = crossing, full bandwidth" },
    "O": { "t": {}, "m": { "oscillator": "square", "hollowStrike": true, "velocity": 0.7, "filterCutoff": 0.5 }, "b": { "decayMod": 0.8, "releaseMod": 0.8 }, "desc": "Hollow Strike — O = round, hollow" },
    "V": { "t": {}, "m": { "oscillator": "triangle", "smoothTransient": true, "velocity": 0.5 }, "b": { "attackMod": 2.0, "decayMod": 0.6, "swellMod": 0.3 }, "desc": "Smooth Transient — V = gradual shape" },
    "I": { "t": {}, "m": { "oscillator": "sawtooth", "narrowStrike": true, "width": 0.1, "velocity": 0.6, "resonance": 6 }, "b": { "staccato": true, "filterSweep": "down" }, "desc": "Narrow Pulse Strike — I = thin line" },

    "#": { "t": { "noiseSeed": true }, "m": { "oscillator": "noise", "addWhiteNoise": true, "noiseLevel": 0.8, "velocity": 0.7 }, "b": { "decayMod": 0.3, "percussive": true }, "desc": "White Noise Burst — hash = static/interference" },
    "@": { "t": { "reverbSend": 0.2 }, "m": { "oscillator": "noise", "addPinkNoise": true, "noiseLevel": 0.8, "velocity": 0.6 }, "b": { "decayMod": 0.5, "granularOverride": 0.3 }, "desc": "Pink Noise Crush — at = colored noise" },
    "%": { "t": { "delaySend": 0.2, "panMod": 0.2 }, "m": { "oscillator": "sine", "addInharmonicFM": true, "metallic": true, "velocity": 0.7, "modIndex": 500 }, "b": { "decayMod": 0.4, "crossModPop": true }, "desc": "Metallic FM — percent = modulation remainder" },
    "W": { "t": { "delaySend": 0.2, "reverbSend": 0.2 }, "m": { "oscillator": "sawtooth", "heavyOverdrive": true, "distortion": 2.0, "velocity": 0.9 }, "b": { "distortion": 0.5, "granularOverride": 0.4, "decayMod": 0.8 }, "desc": "Heavy Overdrive — W = wide, distorted" },

    "/": { "t": {}, "m": { "oscillator": "sawtooth", "velocity": 0.5 }, "b": { "attackMod": 5.0, "swellMod": 0.6, "filterSweep": "up" }, "desc": "Filter Ramp Up — forward slash = rising" },
    "\\": { "t": {}, "m": { "oscillator": "square", "velocity": 0.6 }, "b": { "decayMod": 0.2, "percussive": true, "filterSweep": "down" }, "desc": "Filter Ramp Down — backslash = falling" },
    "\u2554": { "t": {}, "m": { "oscillator": "sawtooth", "velocity": 0.5 }, "b": { "lfoStart": true, "attackMod": 0.5 }, "desc": "LFO Start — box draw corner = beginning" },
    "\u2550": { "t": {}, "m": { "oscillator": "sine", "velocity": 0.4, "sustain": true, "tie": true }, "b": { "infiniteHold": true, "releaseMod": 3.0 }, "desc": "Infinite Hold — double line = continuous" },
    "\u255d": { "t": {}, "m": { "oscillator": "triangle", "velocity": 0.4 }, "b": { "lfoEnd": true, "decayMod": 0.3 }, "desc": "LFO End — box draw corner = end" },
    "\u256c": { "t": { "crossFade": 0.5, "delaySend": 0.2 }, "m": { "oscillator": "sawtooth", "addInharmonicFM": true, "velocity": 0.7 }, "b": { "crossModPop": true, "decayMod": 0.3 }, "desc": "Cross-Modulation Pop — crossing lines = modulation" },

    "\u2591": { "t": { "reverbSend": 0.2 }, "m": { "oscillator": "noise", "velocity": 0.4 }, "b": { "granularOverride": 0.2, "decayMod": 0.8, "attackMod": 0.5 }, "desc": "Sparse Granular (20%) — light shade = sparse" },
    "\u2592": { "t": { "reverbSend": 0.3 }, "m": { "oscillator": "noise", "velocity": 0.5 }, "b": { "granularOverride": 0.5, "decayMod": 0.6, "attackMod": 0.3 }, "desc": "Medium Granular (50%) — medium shade = grainy" },
    "\u2593": { "t": { "reverbSend": 0.4, "delaySend": 0.2 }, "m": { "oscillator": "noise", "velocity": 0.6, "denseStrike": true }, "b": { "granularOverride": 0.8, "distortion": 1.0, "decayMod": 0.4 }, "desc": "Dense Granular (80%) — dark shade = dense" },
    "\u2588": { "t": { "delaySend": 0.3, "reverbSend": 0.2 }, "m": { "oscillator": "sawtooth", "denseStrike": true, "velocity": 1.0, "filterCutoff": 1.0 }, "b": { "granularOverride": 1.0, "distortion": 3.0, "decayMod": 1.5 }, "desc": "Solid Granular Wall (100%) — full block = maximum" },

    "\u2824": { "t": { "ratchetCount": 2, "microTiming": 0.02 }, "m": { "oscillator": "square", "velocity": 0.5 }, "b": { "staccato": true, "decayMod": 0.3 }, "desc": "Double Ratchet — braille dots = rhythmic subdivision" },
    "\u2847": { "t": {}, "m": { "oscillator": "sawtooth", "denseStrike": true, "velocity": 0.8 }, "b": { "attackMod": 0.3, "percussive": true }, "desc": "Vertical Chord — braille column = stacked hit" },
    "\u2809": { "t": { "microTiming": -0.03 }, "m": { "oscillator": "triangle", "velocity": 0.5, "highTick": true }, "b": { "staccato": true, "filterSweep": "up" }, "desc": "High Arp — braille top dots = high register" },
    "\u2812": { "t": { "microTiming": 0.01 }, "m": { "oscillator": "sine", "velocity": 0.5 }, "b": { "decayMod": 0.5, "swellMod": 0.3 }, "desc": "Mid Arp — braille mid dots = middle register" },
    "\u287f": { "t": { "ratchetCount": 3, "probability": 0.7, "delaySend": 0.2 }, "m": { "oscillator": "noise", "addWhiteNoise": true, "velocity": 0.8 }, "b": { "granularOverride": 0.6, "decayMod": 0.2, "staccato": true }, "desc": "Glitch Burst — braille full left = glitchy" },
    "\u28ff": { "t": { "ratchetCount": 4, "delaySend": 0.3, "reverbSend": 0.3 }, "m": { "oscillator": "sawtooth", "denseStrike": true, "velocity": 1.0, "addWhiteNoise": true, "noiseLevel": 0.5 }, "b": { "granularOverride": 1.0, "distortion": 2.0, "decayMod": 1.2, "attackMod": 0.2 }, "desc": "Full Matrix — braille all dots = maximum density" },

    "K": { "t": {}, "m": { "type": "tau_synth", "model": 1, "toneFreq": 60, "decay": 0.3 }, "b": { "decayMod": 0.8, "percussive": true }, "desc": "Kick (Classic Analog)" },
