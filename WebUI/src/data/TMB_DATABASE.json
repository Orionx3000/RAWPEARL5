  "domainKeys": {
    "t": ["delaySend", "reverbSend", "ratchetCount", "probability", "panMod", "loopStart", "loopEnd", "microTiming", "crossFade", "noiseSeed", "chopperRate"],
    "m": ["type", "model", "oscillator", "wave", "velocity", "denseStrike", "hollowStrike", "softStrike", "narrowStrike", "width", "smoothTransient", "ghostNote", "sustain", "tie", "subEmphasis", "subBass", "toneFreq", "highTick", "addWhiteNoise", "addPinkNoise", "addInharmonicFM", "noiseLevel", "heavyOverdrive", "distortion", "filterCutoff", "resonance", "modIndex", "metallic", "color", "filter"],
