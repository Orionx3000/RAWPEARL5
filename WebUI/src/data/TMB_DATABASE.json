    "g": { "t": { "reverbSend": 0.2 }, "m": { "type": "w_synth", "model": 11, "decay": 0.2, "filter": "bandpass", "filterCutoff": 0.4 }, "b": { "granularOverride": 0.4, "decayMod": 0.7 }, "desc": "Granular Clap (Noise Bursts)" },
    "j": { "t": { "probability": 0.8, "microTiming": 0.04 }, "m": { "type": "w_synth", "model": 5, "decay": 0.12, "toneFreq": 250, "filter": "bandpass", "filterCutoff": 0.4 }, "b": { "granularOverride": 0.3, "decayMod": 0.5 }, "desc": "Jitter Snare (Randomized)" },
